{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SERVER;Database=BlindIdeaDB;User Id=YOUR_USER;Password=YOUR_PASSWORD;TrustServerCertificate=True;MultipleActiveResultSets=True"
  },
  "Jwt": {
    "Key": "REPLACE_WITH_SECURE_KEY_FROM_ENVIRONMENT_VARIABLE",
    "Issuer": "BlindIdeaAPI",
    "Audience": "BlindIdeaClient",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "Email": {
    "From": "REPLACE_WITH_EMAIL",
    "SmtpServer": "smtp.office365.com",
    "Port": 587,
    "Username": "REPLACE_WITH_EMAIL",
    "Password": "REPLACE_WITH_PASSWORD",
    "EnableSsl": true
  },
  "AppBaseUrl": "http://localhost:5218"
}
